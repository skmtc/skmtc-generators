{
  "name": "@skmtc/gen-tanstack-query-supabase-zod",
  "version": "0.2.2",
  "exports": "./mod.ts",
  "imports": {
    "@skmtc/gen-zod": "jsr:@skmtc/gen-zod@0.2.1",
    "@skmtc/gen-typescript": "jsr:@skmtc/gen-typescript@0.2.1",
    "@skmtc/core": "jsr:@skmtc/core@0.24.0",
    "@skmtc/lang-typescript": "jsr:@skmtc/lang-typescript@0.12.9"
  },
  "tasks": {
    "test": "deno test --allow-env --allow-sys --allow-read || true",
    "test:coverage": "deno test --allow-env --allow-sys --allow-read --coverage=coverage || true",
    "coverage:report": "deno coverage coverage --lcov --output=coverage.lcov 2>/dev/null || echo 'No coverage data'",
    "coverage:html": "deno coverage coverage --html || true",
    "coverage:check": "deno coverage coverage --detailed || true",
    "publish": "JSR_URL=https://jsr.skmtc.co.uk/ deno publish --allow-slow-types --allow-dirty --token=$JSR_AUTH_TOKEN"
  }
}