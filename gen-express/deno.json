{
  "name": "@skmtc/gen-express",
  "version": "0.1.0",
  "exports": "./mod.ts",
  "imports": {
    "@skmtc/gen-valibot": "jsr:@skmtc/gen-valibot@0.0.68",
    "@skmtc/gen-typescript": "jsr:@skmtc/gen-typescript@0.0.70",
    "@skmtc/core": "jsr:@skmtc/core@0.10.0",
    "@skmtc/lang-typescript": "jsr:@skmtc/lang-typescript@0.3.0"
  },
  "tasks": {
    "test": "deno test --allow-env --allow-sys --allow-read || true",
    "test:coverage": "deno test --allow-env --allow-sys --allow-read --coverage=coverage || true",
    "coverage:report": "deno coverage coverage --lcov --output=coverage.lcov 2>/dev/null || echo 'No coverage data'",
    "coverage:html": "deno coverage coverage --html || true",
    "coverage:check": "deno coverage coverage --detailed || true",
    "publish": "JSR_URL=https://jsr.skmtc.dev/ deno publish --allow-slow-types --allow-dirty --token=$JSR_AUTH_TOKEN"
  }
}
